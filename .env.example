# HaMm3r Core OS — Environment Configuration
# Copy to .env and fill in your keys

# ─── App Identity ────────────────────────────────
APP_NAME=HaMm3r's Agent OS
WEBUI_NAME=HaMm3r's Agent OS
WEBUI_AUTH=False

# ─── Server ──────────────────────────────────────
HOST=0.0.0.0
PORT=3000
DATA_DIR=/Users/YOUR_USERNAME/open-webui/data

# ─── AI Providers ────────────────────────────────
# Google Gemini (primary — free via aistudio.google.com)
OPENAI_API_BASE_URLS="https://generativelanguage.googleapis.com/v1beta/openai"
OPENAI_API_KEY="your-gemini-api-key-here"

# Anthropic Claude (optional — requires API billing at console.anthropic.com)
# ENABLE_ANTHROPIC_API=true
# To add: OPENAI_API_BASE_URLS="https://generativelanguage.googleapis.com/v1beta/openai;https://api.anthropic.com/v1"
# To add: OPENAI_API_KEY="your-gemini-key;your-anthropic-key"

# Ollama (local models)
OLLAMA_BASE_URL=http://127.0.0.1:11434
ENABLE_OLLAMA_API=true

# ─── Security ────────────────────────────────────
ENABLE_SIGNUP=false
WEBUI_SECRET_KEY=change-this-to-a-strong-random-value

# ─── RAG / Search ────────────────────────────────
ENABLE_RAG_WEB_SEARCH=true
RAG_WEB_SEARCH_ENGINE=searxng
SEARXNG_QUERY_URL="http://localhost:8080/search?q=<query>&format=json"
VECTOR_DB=chroma
ENABLE_RAG_HYBRID_SEARCH=true

# ─── Firecrawl (web research) ────────────────────
FIRECRAWL_API_KEY=your-firecrawl-api-key-here

# ─── Features ────────────────────────────────────
ENABLE_IMAGE_GENERATION=false
ENABLE_COMMUNITY_SHARING=false
ENABLE_TELEMETRY=false

# ─── Tailscale Access ────────────────────────────
# Access HaMm3r OS from any device on your Tailscale network:
# http://<your-mac-tailscale-ip>:3000
# Run: tailscale ip -4  to get your Mac's Tailscale IP
