# HaMm3r Corp OS — Environment Variables
# Copy to .env for local dev. On Railway, set these in the Variables tab.

# ── App Identity ──────────────────────────────────────────────
WEBUI_NAME=HaMm3r Corp OS
APP_NAME=HaMm3r Corp OS

# ── Network ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
WEBUI_ORIGIN=https://hammer-corp-os-production.up.railway.app

# ── Auth ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=changeme-use-openssl-rand-hex-32
# Set to False for single-user personal deploy
WEBUI_AUTH=True
ENABLE_SIGNUP=false

# ── Storage ───────────────────────────────────────────────────
DATA_DIR=/app/data

# ── AI Providers ─────────────────────────────────────────────
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Integrations ──────────────────────────────────────────────
FIRECRAWL_API_KEY=
WHISPER_MODEL=base
CHROMA_HOST=
CHROMA_PORT=8000

# ── Logging ───────────────────────────────────────────────────
GLOBAL_LOG_LEVEL=WARNING
RESET_CONFIG_ON_START=False
